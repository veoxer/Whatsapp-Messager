HOST=127.0.0.1
PORT=3030
NODE_ENV=development

# Local development can run without a key while HOST is loopback.
# Set REQUIRE_API_KEY=true to force authentication locally too.
# If API_KEY is set, requests must include either:
# Authorization: Bearer your-secret
# or:
# x-api-key: your-secret
API_KEY=
REQUIRE_API_KEY=false

# Set to false if you want to watch the browser window while testing.
PUPPETEER_HEADLESS=true
CHROME_NO_SANDBOX=false

AUTH_DATA_PATH=.wwebjs_auth
REQUEST_BODY_LIMIT=32kb
GENERAL_RATE_LIMIT_MAX=120
SEND_RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000
MESSAGE_MAX_LENGTH=4096
WHATSAPP_TIMEOUT_MS=30000
READY_TIMEOUT_MS=180000
EXIT_ON_READY_TIMEOUT=false
CLEAN_CHROME_LOCKS_ON_START=true
DEBUG_DIR=/home/node/.cache/whatsapp-api-debug
DEBUG_SCREENSHOT_ON_READY_TIMEOUT=true
AUTO_DISMISS_POPUPS=true
POPUP_DISMISS_INTERVAL_MS=15000
